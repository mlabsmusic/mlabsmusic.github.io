---
interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  bodyClass?: string;
}

const {
  title,
  description,
  canonicalPath = '/',
  bodyClass = '',
} = Astro.props;

const canonical = new URL(canonicalPath, 'https://www.mlabsmusic.com').toString();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#061114" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="MLABS Recordpool" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://www.mlabsmusic.com/assets/video/mlabs-hero-poster.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://www.mlabsmusic.com/assets/video/mlabs-hero-poster.jpg" />
    <link rel="icon" href="/assets/brand/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/assets/brand/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="stylesheet" href="/assets/site.css" />
    <noscript><style>.page-wrap,.reveal{opacity:1;transform:none}</style></noscript>
  </head>
  <body class={bodyClass}>
    <svg class="liquid-glass-filter" aria-hidden="true" focusable="false">
      <filter id="liquid-glass" x="-20%" y="-20%" width="140%" height="140%">
        <feTurbulence type="fractalNoise" baseFrequency="0.012 0.035" numOctaves="2" seed="8" result="noise" />
        <feDisplacementMap in="SourceGraphic" in2="noise" scale="10" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </svg>
    <slot />
    <script src="/assets/site.js" is:inline></script>
    <script>
      import '../scripts/authNav';
    </script>
  </body>
</html>
