---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Owner Review | MLabs Recordpool"
  description="Revision owner de PRs musicales hacia 0_MASTER LIBRARY."
  canonicalPath="/admin"
  bodyClass="app-body"
>
  <div class="page-wrap">
    <header class="site-header">
      <nav class="nav" aria-label="Principal">
        <a class="brand" href="/">MLABS RECORDPOOL</a>
        <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="primaryMenu" aria-label="Abrir menu">
          <span></span><span></span><span></span>
        </button>
        <div class="nav-links" id="primaryMenu">
          <a href="/">Inicio</a>
          <a href="/workspace">Workspace</a>
          <a class="is-auth-hidden" href="/admin" data-auth-link="admin">Owner Review</a>
        </div>
        <button class="button primary" type="button" id="ownerSignOutButton">Cerrar sesion</button>
      </nav>
    </header>

    <main class="dashboard-screen">
      <section class="dashboard-hero dashboard-hero-compact shell reveal">
        <p class="eyebrow">Owner review</p>
        <h1>Revision de cambios para 0_MASTER LIBRARY</h1>
        <p id="ownerSummary">Validando permisos owner y cargando solicitudes musicales...</p>
      </section>

      <section class="shell admin-layout admin-layout-review">
        <aside class="admin-panel">
          <h2>PRs pendientes</h2>
          <div class="admin-list" id="pendingPrList"></div>
        </aside>

        <section class="admin-panel">
          <div class="admin-panel-head">
            <div>
              <h2>Detalle de revision</h2>
              <p id="selectedPrLabel">Selecciona una PR musical.</p>
            </div>
          </div>

          <div class="workspace-timeline" id="prMetaPanel">
            <div class="workspace-empty">Esperando una PR a master.</div>
          </div>

          <h2 class="admin-subtitle">Cambios incluidos</h2>
          <div class="admin-list" id="prChangesList"></div>

          <form class="admin-form" id="ownerReviewForm">
            <label>
              Notas de revision
              <textarea id="ownerReviewNotes" name="review_notes" rows="4" placeholder="Comentario editorial, motivos o feedback para el DJ"></textarea>
            </label>
            <div class="auth-actions">
              <button class="button ghost" type="button" id="rejectPrButton">Rechazar</button>
              <button class="button primary" type="submit">Aprobar y mergear</button>
            </div>
          </form>
        </section>

        <section class="admin-panel admin-panel-history">
          <div class="admin-panel-head">
            <div>
              <h2>Historial reciente</h2>
              <p>Ultimas PRs a master ya revisadas por owner.</p>
            </div>
          </div>
          <div class="admin-list" id="reviewHistoryList"></div>
        </section>
      </section>
    </main>
  </div>

  <script>
    import { supabase, isSupabaseConfigured } from '../lib/supabase';

    const ownerSummary = document.getElementById('ownerSummary');
    const pendingPrList = document.getElementById('pendingPrList');
    const selectedPrLabel = document.getElementById('selectedPrLabel');
    const prMetaPanel = document.getElementById('prMetaPanel');
    const prChangesList = document.getElementById('prChangesList');
    const reviewHistoryList = document.getElementById('reviewHistoryList');
    const ownerReviewForm = document.getElementById('ownerReviewForm');
    const ownerReviewNotes = document.getElementById('ownerReviewNotes');
    const rejectPrButton = document.getElementById('rejectPrButton');
    const signOutButton = document.getElementById('ownerSignOutButton');

    let ownerProfile = null;
    let masterLibrary = null;
    let pendingPrs = [];
    let reviewHistory = [];
    let currentPrId = '';
    let currentPrChanges = [];

    function setSummary(text) {
      if (ownerSummary) ownerSummary.textContent = text;
    }

    function escapeHtml(value) {
      return String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
    }

    function formatDate(value) {
      return new Date(value).toLocaleString('es-ES', {
        dateStyle: 'short',
        timeStyle: 'short',
      });
    }

    async function requireOwner() {
      if (!isSupabaseConfigured || !supabase) {
        setSummary('Configura Supabase para usar el panel owner.');
        return false;
      }

      const { data: sessionData } = await supabase.auth.getSession();
      const session = sessionData.session;

      if (!session) {
        window.location.assign('/login?next=/admin');
        return false;
      }

      const { data: profile, error } = await supabase
        .from('profiles')
        .select('id, email, display_name, role, is_owner')
        .eq('id', session.user.id)
        .single();

      if (error || (!profile?.is_owner && profile?.role !== 'admin')) {
        setSummary('No tienes permisos de owner para revisar la master.');
        return false;
      }

      ownerProfile = profile;
      setSummary(`Owner activo: ${profile.display_name || profile.email}`);

      const { data: library } = await supabase
        .from('libraries')
        .select('id, name, slug, current_working_snapshot_id, current_published_snapshot_id')
        .eq('kind', 'master')
        .single();

      masterLibrary = library || null;
      return true;
    }

    function renderPendingPrs() {
      if (!pendingPrList) return;

      if (!pendingPrs.length) {
        pendingPrList.innerHTML = '<div class="workspace-empty">No hay PRs pendientes ahora mismo.</div>';
        return;
      }

      pendingPrList.innerHTML = pendingPrs.map((pr) => `
        <button class="admin-user ${pr.id === currentPrId ? 'is-active' : ''}" type="button" data-pr-id="${pr.id}">
          <span>
            <strong>${escapeHtml(pr.title)}</strong>
            <small>${escapeHtml(pr.profile_name || 'DJ')} · ${formatDate(pr.created_at)}</small>
          </span>
          <em>${escapeHtml(pr.status)}</em>
        </button>
      `).join('');

      for (const button of pendingPrList.querySelectorAll('[data-pr-id]')) {
        button.addEventListener('click', () => {
          currentPrId = button.dataset.prId || '';
          renderPendingPrs();
          renderCurrentPr();
        });
      }
    }

    function renderCurrentPr() {
      const currentPr = pendingPrs.find((pr) => pr.id === currentPrId);

      if (!currentPr) {
        if (selectedPrLabel) selectedPrLabel.textContent = 'Selecciona una PR musical.';
        if (prMetaPanel) prMetaPanel.innerHTML = '<div class="workspace-empty">Esperando una PR a master.</div>';
        if (prChangesList) prChangesList.innerHTML = '<div class="workspace-empty">No hay cambios cargados.</div>';
        if (ownerReviewNotes) ownerReviewNotes.value = '';
        return;
      }

      if (selectedPrLabel) selectedPrLabel.textContent = `${currentPr.title} · ${currentPr.profile_name || 'DJ'}`;
      if (ownerReviewNotes) ownerReviewNotes.value = currentPr.review_notes || '';

      if (prMetaPanel) {
        prMetaPanel.innerHTML = `
          <article class="workspace-timeline-card">
            <div class="workspace-timeline-head">
              <strong>${escapeHtml(currentPr.title)}</strong>
              <span>${formatDate(currentPr.created_at)}</span>
            </div>
            <p>${escapeHtml(currentPr.description || 'Sin descripcion')}</p>
            <small>Origen: ${escapeHtml(currentPr.library_name || 'Library')} · owner review hacia 0_MASTER LIBRARY</small>
          </article>
        `;
      }

      if (!prChangesList) return;
      if (!currentPrChanges.length) {
        prChangesList.innerHTML = '<div class="workspace-empty">Esta PR no tiene cambios detallados cargados.</div>';
        return;
      }

      prChangesList.innerHTML = currentPrChanges.map((change) => `
        <article class="workspace-change-row is-${change.change_type}">
          <div>
            <strong>${escapeHtml(change.entity_key)}</strong>
            <p>${escapeHtml(change.change_type)} · ${escapeHtml(change.after_json?.detail || change.before_json?.detail || 'Cambio sin detalle')}</p>
          </div>
          <span>${escapeHtml(change.change_type)}</span>
        </article>
      `).join('');
    }

    function renderHistory() {
      if (!reviewHistoryList) return;

      if (!reviewHistory.length) {
        reviewHistoryList.innerHTML = '<div class="workspace-empty">Todavia no hay PRs revisadas.</div>';
        return;
      }

      reviewHistoryList.innerHTML = reviewHistory.map((pr) => `
        <article class="workspace-timeline-card">
          <div class="workspace-timeline-head">
            <strong>${escapeHtml(pr.title)}</strong>
            <span>${formatDate(pr.created_at)}</span>
          </div>
          <p>${escapeHtml(pr.description || 'Sin descripcion')}</p>
          <small>${escapeHtml(pr.status)}${pr.review_notes ? ` · ${escapeHtml(pr.review_notes)}` : ''}</small>
        </article>
      `).join('');
    }

    async function loadReviewData() {
      const allowed = await requireOwner();
      if (!allowed || !supabase) return;

      const { data: changeSets, error } = await supabase
        .from('library_change_sets')
        .select(`
          id,
          title,
          description,
          review_notes,
          target_kind,
          status,
          created_at,
          library_id,
          created_by,
          libraries!inner(name),
          profiles!library_change_sets_created_by_fkey(display_name,email)
        `)
        .eq('target_kind', 'master')
        .order('created_at', { ascending: false });

      if (error) {
        setSummary(`No he podido cargar las PRs: ${error.message}`);
        return;
      }

      const rows = (changeSets || []).map((row) => ({
        ...row,
        library_name: row.libraries?.name,
        profile_name: row.profiles?.display_name || row.profiles?.email,
      }));

      pendingPrs = rows.filter((row) => row.status === 'open');
      reviewHistory = rows.filter((row) => row.status !== 'open').slice(0, 8);
      currentPrId = pendingPrs[0]?.id || '';

      if (currentPrId) {
        const { data: changes } = await supabase
          .from('library_changes')
          .select('id, entity_key, change_type, before_json, after_json, selected_for_master')
          .eq('change_set_id', currentPrId)
          .order('created_at', { ascending: true });
        currentPrChanges = changes || [];
      } else {
        currentPrChanges = [];
      }

      renderPendingPrs();
      renderCurrentPr();
      renderHistory();
    }

    async function approveCurrentPr(status) {
      const currentPr = pendingPrs.find((pr) => pr.id === currentPrId);
      if (!currentPr || !ownerProfile || !supabase || !masterLibrary) return;

      const notes = ownerReviewNotes?.value?.trim() || '';

      if (status === 'merged') {
        const masterSnapshotPayload = {
          library_id: masterLibrary.id,
          created_by: ownerProfile.id,
          label: `Master merge · ${currentPr.title}`,
          source_kind: 'browser_demo',
          root_path: '0_MASTER LIBRARY',
          file_count: currentPrChanges.length,
          total_bytes: 0,
          based_on_snapshot_id: masterLibrary.current_published_snapshot_id || null,
          snapshot_json: currentPrChanges.map((change) => ({
            entity_key: change.entity_key,
            change_type: change.change_type,
            detail: change.after_json?.detail || change.before_json?.detail || '',
          })),
        };

        const snapshotInsert = await supabase
          .from('library_snapshots')
          .insert(masterSnapshotPayload)
          .select('id')
          .single();

        if (snapshotInsert.error) {
          setSummary(`No he podido crear el snapshot master: ${snapshotInsert.error.message}`);
          return;
        }

        const libraryUpdate = await supabase
          .from('libraries')
          .update({
            current_working_snapshot_id: snapshotInsert.data.id,
            current_published_snapshot_id: snapshotInsert.data.id,
            updated_at: new Date().toISOString(),
          })
          .eq('id', masterLibrary.id)
          .select('id, name, slug, current_working_snapshot_id, current_published_snapshot_id')
          .single();

        if (libraryUpdate.error) {
          setSummary(`He creado el snapshot master, pero no actualice la libreria: ${libraryUpdate.error.message}`);
          return;
        }

        masterLibrary = libraryUpdate.data;
      }

      const updateResult = await supabase
        .from('library_change_sets')
        .update({
          status,
          reviewed_by: ownerProfile.id,
          review_notes: notes || (status === 'merged' ? 'Aprobado por owner.' : 'Rechazado por owner.'),
          merged_at: status === 'merged' ? new Date().toISOString() : null,
          updated_at: new Date().toISOString(),
        })
        .eq('id', currentPr.id);

      if (updateResult.error) {
        setSummary(`No he podido actualizar la PR: ${updateResult.error.message}`);
        return;
      }

      setSummary(status === 'merged' ? 'PR aprobada y mergeada a 0_MASTER LIBRARY.' : 'PR rechazada.');
      await loadReviewData();
    }

    ownerReviewForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      await approveCurrentPr('merged');
    });

    rejectPrButton?.addEventListener('click', async () => {
      await approveCurrentPr('rejected');
    });

    signOutButton?.addEventListener('click', async () => {
      await supabase?.auth.signOut();
      window.location.assign('/login');
    });

    loadReviewData();
  </script>
</BaseLayout>
