---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  demoPullRequests,
  demoBranches,
  demoWorkingChanges,
  gitMusicFlow,
  gitMusicMetrics,
  gitMusicPrinciples,
  sampleLocalTree,
} from '../data/gitMusicData';
---

<BaseLayout
  title="Git Musical Workspace | MLabs Recordpool"
  description="Espacio para revisar cambios en tu biblioteca, guardar su estado y decidir qué compartes dentro del recordpool."
  canonicalPath="/workspace"
  bodyClass="app-body workspace-body"
>
  <div class="page-wrap">
    <header class="site-header">
      <nav class="nav" aria-label="Principal">
        <a class="brand" href="/">MLABS RECORDPOOL</a>
        <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="primaryMenu" aria-label="Abrir menu">
          <span></span><span></span><span></span>
        </button>
        <div class="nav-links" id="primaryMenu">
          <a href="/">Inicio</a>
          <a href="/djs">DJs</a>
          <a href="/recordpool">Recordpool</a>
          <a href="/workspace">Workspace</a>
        </div>
      </nav>
    </header>

    <main class="workspace-screen">
      <section class="shell workspace-hero reveal">
        <div class="workspace-hero-copy">
          <p class="eyebrow">Tu espacio de trabajo</p>
          <h1>Tu librería no solo se guarda: aquí se ordena, se cuida y se prepara para crecer.</h1>
          <p>
            Este espacio reúne lo que un DJ necesita para trabajar con criterio: leer su carpeta local, detectar cambios,
            guardar versiones y decidir qué material se queda privado y qué pasa al pool.
          </p>
        </div>
        <div class="workspace-metric-row">
          {gitMusicMetrics.map((metric) => (
            <article class="workspace-metric-card">
              <strong>{metric.value}</strong>
              <span>{metric.label}</span>
            </article>
          ))}
        </div>
      </section>

      <section class="shell workspace-shell reveal">
        <section class="workspace-main">
          <div class="workspace-toolbar">
            <div>
              <p class="workspace-kicker">Workspace actual</p>
              <h2 id="workspaceTitle">MARQUES EDITION / Biblioteca en curso</h2>
            </div>
            <div class="workspace-toolbar-actions">
              <button class="recordpool-row-button" id="saveSnapshotButton" type="button">Guardar estado</button>
              <button class="recordpool-row-button" id="mergePublishedButton" type="button">Pasar a estable</button>
              <button class="recordpool-row-button is-primary" id="stageSelectionButton" type="button">Compartir cambios</button>
            </div>
          </div>

          <section class="workspace-connection-grid">
            <article class="workspace-panel">
              <div class="workspace-panel-head">
                <div>
                  <p class="workspace-kicker">Carpeta local</p>
                  <h3>Donde empieza tu colección</h3>
                </div>
                <label class="workspace-connect-button">
                  <input id="localFolderInput" type="file" webkitdirectory directory multiple />
                  Conectar carpeta
                </label>
              </div>
              <p class="workspace-sidebar-copy">
                Conecta tu librería tal y como la trabajas a diario y conviértela en una base mucho más fácil de revisar y evolucionar.
              </p>
              <div class="workspace-source-status">
                <span id="workspaceSourceName">Sin carpeta conectada</span>
                <small id="workspaceSourceMeta">Todavia no hay snapshot local.</small>
              </div>
            </article>

            <article class="workspace-panel">
              <div class="workspace-panel-head">
                <div>
                  <p class="workspace-kicker">Estado cloud</p>
                  <h3>Tu espacio guardado</h3>
                </div>
                <span class="workspace-badge" id="workspaceCloudBadge">Modo local</span>
              </div>
              <p class="workspace-sidebar-copy" id="workspaceCloudCopy">
                Inicia sesión para guardar tu historial, mantener tu biblioteca viva y seguir tu trabajo desde cualquier momento.
              </p>
              <div class="workspace-source-status">
                <span id="workspaceCloudUser">Sin sesion iniciada</span>
                <small id="workspaceCloudLibrary">No hay libreria cloud activa.</small>
              </div>
            </article>
          </section>

          <section class="workspace-panel workspace-branch-panel">
            <div class="workspace-panel-head">
              <div>
                <p class="workspace-kicker">Ramas musicales</p>
                <h3>Trabaja como Git, pero con crates, sets y master</h3>
              </div>
              <span class="workspace-badge" id="workspaceBranchBadge">working</span>
            </div>

            <div class="workspace-branch-layout">
              <div>
                <p class="workspace-sidebar-copy">
                  Crea ramas para preparar un crate, limpiar tags, probar un set o seleccionar promos. Nada toca la rama estable hasta que haces merge.
                </p>
                <form class="workspace-branch-form" id="branchForm">
                  <label>
                    Nueva rama
                    <input id="branchNameInput" type="text" placeholder="crate/latin-promos" autocomplete="off" />
                  </label>
                  <button class="recordpool-row-button is-primary" type="submit">Crear rama</button>
                </form>
              </div>
              <div class="workspace-branch-list" id="workspaceBranchList"></div>
            </div>
          </section>

          <section class="workspace-panel workspace-graph-panel">
            <div class="workspace-panel-head">
              <div>
                <p class="workspace-kicker">Git graph musical</p>
                <h3>Historial visual de ramas, snapshots y PRs</h3>
              </div>
              <span class="workspace-badge" id="workspaceGraphSummary">Graph local</span>
            </div>
            <div class="workspace-graph-shell">
              <div class="workspace-graph-head" aria-hidden="true">
                <span>Graph</span>
                <span>Commit musical</span>
                <span>Rama</span>
                <span>Estado</span>
              </div>
              <div class="workspace-graph-list" id="workspaceGitGraph"></div>
            </div>
          </section>

          <section class="workspace-panel workspace-agent-panel">
            <div class="workspace-panel-head">
              <div>
                <p class="workspace-kicker">Ingesta local</p>
                <h3>La ruta recomendada para traer música real</h3>
              </div>
              <span class="workspace-badge">Mac agent</span>
            </div>
            <div class="workspace-agent-grid">
              <article>
                <strong>1. App macOS</strong>
                <p>Selecciona una carpeta desde Finder, guarda credenciales y deja el watch activo mientras trabajas tu librería.</p>
                <code>dist/MLABSFolderAgent.app</code>
              </article>
              <article>
                <strong>2. Agent CLI</strong>
                <p>Para demo o diagnóstico, el mismo motor puede lanzar una lectura puntual o quedarse vigilando una ruta.</p>
                <code>npm run agent:watch -- "/ruta/a/libreria"</code>
              </article>
              <article>
                <strong>3. Review owner</strong>
                <p>Los cambios llegan como snapshots y change sets. El DJ decide qué comparte y owner publica el master.</p>
                <a class="recordpool-row-button is-primary" href="/admin">Abrir owner review</a>
              </article>
            </div>
          </section>

          <section class="workspace-grid">
            <article class="workspace-panel">
              <div class="workspace-panel-head">
                <div>
                  <p class="workspace-kicker">Cambios recientes</p>
                  <h3>Lo que se ha movido en tu librería</h3>
                </div>
                <span class="workspace-badge" id="workspaceDiffSummary">0 cambios</span>
              </div>
              <div class="workspace-change-list" id="workspaceChangeList">
                {demoWorkingChanges.map((change) => (
                  <label class={`workspace-change-row is-${change.type}`}>
                    <input type="checkbox" data-change-id={change.id} />
                    <div>
                      <strong>{change.title}</strong>
                      <p>{change.detail}</p>
                    </div>
                    <span>{change.type}</span>
                  </label>
                ))}
              </div>
              <div class="workspace-empty" id="workspaceEmpty" hidden>
                Todo está al día. No hay cambios pendientes por revisar.
              </div>
            </article>

            <article class="workspace-panel">
              <div class="workspace-panel-head">
                <div>
                  <p class="workspace-kicker">Cambios compartidos</p>
                  <h3>Lo que sube a revisión</h3>
                </div>
                <span class="workspace-badge" id="workspacePrCount">0 activas</span>
              </div>
              <div class="workspace-pr-list" id="workspacePrList">
                {demoPullRequests.map((pr) => (
                  <article class={`workspace-pr-card is-${pr.status}`}>
                    <div class="workspace-pr-card-head">
                      <strong>{pr.title}</strong>
                      <span>{pr.status}</span>
                    </div>
                    <p>{pr.summary}</p>
                    <small>Destino: {pr.target}</small>
                  </article>
                ))}
              </div>
            </article>

            <article class="workspace-panel workspace-panel-wide">
              <div class="workspace-panel-head">
                <div>
                  <p class="workspace-kicker">Como funciona</p>
                  <h3>Un flujo pensado para trabajar mejor</h3>
                </div>
              </div>
              <div class="workspace-flow-grid">
                {gitMusicFlow.map((item) => (
                  <article class="workspace-flow-card">
                    <span>{item.step}</span>
                    <strong>{item.title}</strong>
                    <p>{item.body}</p>
                  </article>
                ))}
              </div>
            </article>

            <article class="workspace-panel workspace-panel-wide">
              <div class="workspace-panel-head">
                <div>
                  <p class="workspace-kicker">Lectura local</p>
                  <h3>Vista rápida de tu carpeta</h3>
                </div>
                <span class="workspace-badge" id="workspaceFileSummary">0 archivos</span>
              </div>
              <div class="workspace-file-table-wrap">
                <table class="workspace-file-table">
                  <thead>
                    <tr>
                      <th>Path</th>
                      <th>Tamano</th>
                      <th>Modificado</th>
                      <th>Firma</th>
                    </tr>
                  </thead>
                  <tbody id="workspaceFileTableBody">
                    <tr class="workspace-file-placeholder">
                      <td colspan="4">Conecta una carpeta para ver aquí los archivos detectados.</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </article>

            <article class="workspace-panel workspace-panel-wide">
              <div class="workspace-panel-head">
                <div>
                  <p class="workspace-kicker">Historial</p>
                  <h3>Versiones que merece conservar</h3>
                </div>
                <span class="workspace-badge" id="workspaceSnapshotCount">0 guardados</span>
              </div>
              <div class="workspace-timeline" id="workspaceSnapshotTimeline">
                <div class="workspace-empty">
                  Inicia sesión y guarda un primer estado para empezar a crear tu historial.
                </div>
              </div>
            </article>
          </section>
        </section>

        <aside class="workspace-sidebar">
          <div class="workspace-sidebar-block">
            <p class="workspace-sidebar-title">Principios</p>
            <div class="workspace-principles">
              {gitMusicPrinciples.map((item) => (
                <article class="workspace-principle-card">
                  <strong>{item.title}</strong>
                  <p>{item.body}</p>
                </article>
              ))}
            </div>
          </div>

          <div class="workspace-sidebar-block">
            <p class="workspace-sidebar-title">Branch graph</p>
            <div class="workspace-branch-graph" id="workspaceBranchGraph"></div>
          </div>

          <div class="workspace-sidebar-block">
            <p class="workspace-sidebar-title">Base actual del pool</p>
            <div class="workspace-tree">
              {sampleLocalTree.map((node) => (
                <div class="workspace-tree-root">
                  <strong>{node.name}</strong>
                  <ul>
                    {node.children.map((child) => (
                      <li>
                        <span>{child.name}</span>
                        {child.children && (
                          <ul>
                            {child.children.map((leaf) => (
                              <li>{leaf.name}</li>
                            ))}
                          </ul>
                        )}
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        </aside>
      </section>
    </main>
  </div>

  <script id="workspaceBranchSeed" type="application/json" set:html={JSON.stringify(demoBranches)}></script>

  <script>
    import { supabase, isSupabaseConfigured } from '../lib/supabase';

    const input = document.getElementById('localFolderInput');
    const sourceName = document.getElementById('workspaceSourceName');
    const sourceMeta = document.getElementById('workspaceSourceMeta');
    const title = document.getElementById('workspaceTitle');
    const fileSummary = document.getElementById('workspaceFileSummary');
    const fileTableBody = document.getElementById('workspaceFileTableBody');
    const diffSummary = document.getElementById('workspaceDiffSummary');
    const changeList = document.getElementById('workspaceChangeList');
    const emptyState = document.getElementById('workspaceEmpty');
    const saveSnapshotButton = document.getElementById('saveSnapshotButton');
    const mergePublishedButton = document.getElementById('mergePublishedButton');
    const stageSelectionButton = document.getElementById('stageSelectionButton');
    const prList = document.getElementById('workspacePrList');
    const prCount = document.getElementById('workspacePrCount');
    const cloudBadge = document.getElementById('workspaceCloudBadge');
    const cloudCopy = document.getElementById('workspaceCloudCopy');
    const cloudUser = document.getElementById('workspaceCloudUser');
    const cloudLibrary = document.getElementById('workspaceCloudLibrary');
    const snapshotTimeline = document.getElementById('workspaceSnapshotTimeline');
    const snapshotCount = document.getElementById('workspaceSnapshotCount');
    const branchSeed = JSON.parse(document.getElementById('workspaceBranchSeed')?.textContent || '[]');
    const branchList = document.getElementById('workspaceBranchList');
    const branchGraph = document.getElementById('workspaceBranchGraph');
    const branchBadge = document.getElementById('workspaceBranchBadge');
    const branchForm = document.getElementById('branchForm');
    const branchNameInput = document.getElementById('branchNameInput');
    const gitGraph = document.getElementById('workspaceGitGraph');
    const graphSummary = document.getElementById('workspaceGraphSummary');

    const STORAGE_KEY = 'mlabs_git_music_snapshot_v1';
    const BRANCH_STORAGE_KEY = 'mlabs_git_music_branches_v1';
    let currentSnapshot = [];
    let currentChanges = [];
    let currentProfile = null;
    let currentLibrary = null;
    let currentWorkingSnapshotId = '';
    let hasLocalSelection = false;
    let branches = readStoredBranches();
    let activeBranchId = branches.find((branch) => branch.status === 'active')?.id || 'working';

    function readStoredSnapshot() {
      try {
        return JSON.parse(window.localStorage.getItem(STORAGE_KEY) || '[]');
      } catch {
        return [];
      }
    }

    function writeStoredSnapshot(snapshot) {
      window.localStorage.setItem(STORAGE_KEY, JSON.stringify(snapshot));
    }

    function readStoredBranches() {
      try {
        const saved = JSON.parse(window.localStorage.getItem(BRANCH_STORAGE_KEY) || '[]');
        if (Array.isArray(saved) && saved.length) return saved;
      } catch {}
      return branchSeed;
    }

    function writeStoredBranches(nextBranches = branches) {
      window.localStorage.setItem(BRANCH_STORAGE_KEY, JSON.stringify(nextBranches));
    }

    function slugifyBranchName(value) {
      return String(value || '')
        .trim()
        .toLowerCase()
        .replace(/[^a-z0-9/_-]+/g, '-')
        .replace(/-+/g, '-')
        .replace(/^[-/]+|[-/]+$/g, '');
    }

    function activeBranch() {
      return branches.find((branch) => branch.id === activeBranchId) || branches.find((branch) => branch.id === 'working') || branches[0];
    }

    function branchStatusLabel(status) {
      const labels = {
        active: 'checkout',
        protected: 'protegida',
        review: 'en review',
        draft: 'borrador',
      };
      return labels[status] || status || 'branch';
    }

    function graphLaneForBranch(branchName = '') {
      if (branchName.includes('published')) return 'published';
      if (branchName.includes('master') || branchName.includes('0_MASTER')) return 'master';
      if (branchName.includes('crate/')) return 'crate';
      if (branchName.includes('set/')) return 'set';
      return 'working';
    }

    function graphLabelFromSnapshot(snapshot) {
      const label = snapshot?.label || 'Snapshot local';
      const rootPath = snapshot?.root_path || '';
      const branchFromRoot = rootPath.includes(':') ? rootPath.split(':')[0] : '';
      const branchFromLabel = label.includes(' · ') ? label.split(' · ')[0] : '';
      return branchFromRoot || branchFromLabel || 'working';
    }

    function graphStatusLabel(status) {
      const labels = {
        merged: 'merge',
        open: 'review',
        draft: 'draft',
        rejected: 'rejected',
        snapshot: 'snapshot',
        branch: 'branch',
      };
      return labels[status] || status || 'commit';
    }

    function buildFallbackGraphRows() {
      const active = activeBranch()?.name || 'working';
      const rows = [
        {
          id: 'master-live',
          lane: 'master',
          branch: '0_MASTER',
          title: '0_MASTER LIBRARY publicado',
          detail: 'La biblioteca compartida solo cambia con PR aprobada por owner.',
          status: 'merged',
          meta: 'master',
        },
        {
          id: 'published',
          lane: 'published',
          branch: 'published',
          title: 'Biblioteca estable del DJ',
          detail: 'Version lista para pinchar. Recibe merges desde ramas de trabajo.',
          status: 'merged',
          meta: 'local',
        },
        {
          id: active,
          lane: graphLaneForBranch(active),
          branch: active,
          title: `Checkout activo en ${active}`,
          detail: 'Los siguientes snapshots y PRs se etiquetan con esta rama musical.',
          status: 'branch',
          meta: 'HEAD',
        },
        ...branches
          .filter((branch) => branch.name !== active && branch.name !== 'published')
          .slice(0, 4)
          .map((branch) => ({
            id: branch.id,
            lane: graphLaneForBranch(branch.name),
            branch: branch.name,
            title: branch.label || branch.name,
            detail: branch.description,
            status: branch.status || 'branch',
            meta: branch.source || 'working',
          })),
      ];
      return rows;
    }

    function buildCloudGraphRows(snapshots = [], changeSets = []) {
      const rows = [];

      for (const pr of changeSets.slice(0, 8)) {
        const branchName = pr.title?.includes('PR ')
          ? pr.title.replace(/^PR\s+/, '').split(' -> ')[0]
          : pr.title?.includes('Merge ')
            ? pr.title.replace(/^Merge\s+/, '').split(' -> ')[0]
            : pr.target_kind === 'master'
              ? '0_MASTER'
              : 'working';
        rows.push({
          id: `cs-${pr.id}`,
          lane: pr.target_kind === 'master' ? 'master' : graphLaneForBranch(branchName),
          branch: branchName,
          title: pr.title || 'Change set',
          detail: pr.description || pr.review_notes || 'Cambio cloud registrado.',
          status: pr.status || 'open',
          meta: `${pr.target_kind === 'master' ? 'PR master' : 'merge local'} · ${formatDate(pr.created_at)}`,
        });
      }

      for (const snapshot of snapshots.slice(0, 8)) {
        const branchName = graphLabelFromSnapshot(snapshot);
        rows.push({
          id: `snap-${snapshot.id}`,
          lane: graphLaneForBranch(branchName),
          branch: branchName,
          title: snapshot.label || 'Snapshot',
          detail: `${snapshot.file_count || 0} archivos · ${formatBytes(snapshot.total_bytes || 0)} · ${snapshot.source_kind || 'source'}`,
          status: 'snapshot',
          meta: formatDate(snapshot.created_at),
        });
      }

      return rows.length ? rows : buildFallbackGraphRows();
    }

    function renderGitGraph(rows = buildFallbackGraphRows()) {
      if (!gitGraph) return;
      const safeRows = rows.slice(0, 14);
      if (graphSummary) graphSummary.textContent = `${safeRows.length} commits`;
      gitGraph.innerHTML = safeRows.map((row, index) => `
        <article class="workspace-graph-row is-${row.lane}" data-graph-row="${row.id}">
          <div class="workspace-graph-lanes" aria-hidden="true">
            <span class="workspace-graph-line lane-master"></span>
            <span class="workspace-graph-line lane-published"></span>
            <span class="workspace-graph-line lane-working"></span>
            <span class="workspace-graph-line lane-feature"></span>
            <strong class="workspace-graph-dot lane-${row.lane}">${index + 1}</strong>
          </div>
          <div class="workspace-graph-copy">
            <strong>${row.title}</strong>
            <p>${row.detail || 'Sin detalle.'}</p>
            <small>${row.meta || ''}</small>
          </div>
          <span class="workspace-graph-branch">${row.branch}</span>
          <span class="workspace-graph-state is-${row.status}">${graphStatusLabel(row.status)}</span>
        </article>
      `).join('');
    }

    function checkoutBranch(branchId) {
      const target = branches.find((branch) => branch.id === branchId);
      if (!target) return;
      activeBranchId = branchId;
      branches = branches.map((branch) => ({
        ...branch,
        status: branch.id === branchId && branch.status !== 'protected' ? 'active' : (branch.id !== branchId && branch.status === 'active' ? 'draft' : branch.status),
      }));
      writeStoredBranches();
      renderBranches();
      syncBranchContext();
      renderGitGraph();
    }

    function createBranch(name) {
      const cleanName = slugifyBranchName(name);
      if (!cleanName) {
        if (sourceMeta) sourceMeta.textContent = 'Escribe un nombre de rama, por ejemplo crate/latin-promos.';
        return;
      }
      const id = cleanName.replaceAll('/', '-');
      if (branches.some((branch) => branch.id === id || branch.name === cleanName)) {
        checkoutBranch(id);
        return;
      }
      const baseBranch = activeBranch();
      const nextBranch = {
        id,
        name: cleanName,
        label: cleanName.replaceAll('-', ' ').replaceAll('/', ' / '),
        status: 'active',
        source: baseBranch?.name || 'working',
        description: `Rama creada desde ${baseBranch?.name || 'working'} para preparar musica sin tocar published.`,
        createdAt: new Date().toISOString(),
      };
      branches = branches.map((branch) => ({
        ...branch,
        status: branch.status === 'active' ? 'draft' : branch.status,
      })).concat(nextBranch);
      activeBranchId = id;
      writeStoredBranches();
      renderBranches();
      syncBranchContext();
      renderGitGraph();
      if (branchNameInput instanceof HTMLInputElement) branchNameInput.value = '';
      if (sourceMeta) sourceMeta.textContent = `Checkout a ${cleanName}. Los siguientes cambios se guardan en esta rama musical.`;
    }

    function renderBranches() {
      const current = activeBranch();
      if (branchBadge) branchBadge.textContent = current?.name || 'working';

      if (branchList) {
        branchList.innerHTML = branches.map((branch) => `
          <article class="workspace-branch-card ${branch.id === activeBranchId ? 'is-active' : ''} is-${branch.status}">
            <div>
              <span>${branchStatusLabel(branch.status)}</span>
              <strong>${branch.name}</strong>
              <p>${branch.description || 'Rama musical sin descripcion.'}</p>
              <small>base: ${branch.source || 'working'}</small>
            </div>
            <button class="recordpool-row-button ${branch.id === activeBranchId ? 'is-selected' : ''}" type="button" data-checkout-branch="${branch.id}">
              ${branch.id === activeBranchId ? 'Activa' : 'Checkout'}
            </button>
          </article>
        `).join('');

        for (const button of branchList.querySelectorAll('[data-checkout-branch]')) {
          button.addEventListener('click', () => checkoutBranch(button.getAttribute('data-checkout-branch') || ''));
        }
      }

      if (branchGraph) {
        branchGraph.innerHTML = branches.map((branch) => `
          <button class="workspace-branch-node ${branch.id === activeBranchId ? 'is-active' : ''}" type="button" data-graph-branch="${branch.id}">
            <span>${branchStatusLabel(branch.status)}</span>
            <strong>${branch.name}</strong>
          </button>
        `).join('');

        for (const button of branchGraph.querySelectorAll('[data-graph-branch]')) {
          button.addEventListener('click', () => checkoutBranch(button.getAttribute('data-graph-branch') || ''));
        }
      }
    }

    function syncBranchContext() {
      const branch = activeBranch();
      if (!branch) return;
      if (title) {
        const owner = currentProfile?.display_name || sourceName?.textContent || 'DJ';
        title.textContent = `${owner} / ${branch.name}`;
      }
    }

    function totalBytes(snapshot) {
      return snapshot.reduce((sum, item) => sum + (item.size || 0), 0);
    }

    function buildSignature(file) {
      return [file.name, file.size, file.lastModified].join(':');
    }

    function formatBytes(bytes) {
      if (!Number.isFinite(bytes)) return '-';
      if (bytes < 1024) return `${bytes} B`;
      if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
      if (bytes < 1024 * 1024 * 1024) return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
      return `${(bytes / (1024 * 1024 * 1024)).toFixed(2)} GB`;
    }

    function formatDate(value) {
      return new Date(value).toLocaleString('es-ES', {
        dateStyle: 'short',
        timeStyle: 'short',
      });
    }

    function createSnapshot(files) {
      return files.map((file) => ({
        path: file.webkitRelativePath || file.name,
        name: file.name,
        size: file.size,
        lastModified: file.lastModified,
        signature: buildSignature(file),
      })).sort((a, b) => a.path.localeCompare(b.path));
    }

    function diffSnapshots(previous, next) {
      const prevMap = new Map(previous.map((item) => [item.path, item]));
      const nextMap = new Map(next.map((item) => [item.path, item]));
      const changes = [];

      for (const item of next) {
        if (!prevMap.has(item.path)) {
          changes.push({
            id: `add-${item.path}`,
            type: 'added',
            title: item.name,
            detail: `Nuevo archivo en /${item.path}`,
          });
          continue;
        }

        const previousItem = prevMap.get(item.path);
        if (previousItem.signature !== item.signature) {
          changes.push({
            id: `update-${item.path}`,
            type: 'updated',
            title: item.name,
            detail: `Archivo modificado en /${item.path}`,
          });
        }
      }

      for (const item of previous) {
        if (!nextMap.has(item.path)) {
          changes.push({
            id: `remove-${item.path}`,
            type: 'removed',
            title: item.name,
            detail: `Archivo eliminado de /${item.path}`,
          });
        }
      }

      return changes;
    }

    function renderFiles(snapshot, emptyMessage = 'Conecta una carpeta para ver aquí los archivos detectados.') {
      if (!fileTableBody || !fileSummary) return;

      if (!snapshot.length) {
        fileTableBody.innerHTML = `<tr class="workspace-file-placeholder"><td colspan="4">${emptyMessage}</td></tr>`;
        fileSummary.textContent = '0 archivos';
        return;
      }

      fileSummary.textContent = `${snapshot.length} archivos`;
      fileTableBody.innerHTML = snapshot.slice(0, 80).map((file) => `
        <tr>
          <td data-label="Path">${file.path}</td>
          <td data-label="Tamano">${formatBytes(file.size)}</td>
          <td data-label="Modificado">${formatDate(file.lastModified || file.modifiedAt)}</td>
          <td data-label="Firma">${file.signature}</td>
        </tr>
      `).join('');
    }

    function renderChanges(changes) {
      currentChanges = changes;

      if (!changeList || !emptyState || !diffSummary) return;
      if (!changes.length) {
        changeList.innerHTML = '';
        emptyState.hidden = false;
        diffSummary.textContent = 'Sin cambios';
        return;
      }

      emptyState.hidden = true;
      diffSummary.textContent = `${changes.length} cambios`;
      changeList.innerHTML = changes.map((change) => `
        <label class="workspace-change-row is-${change.type}">
          <input type="checkbox" data-change-id="${change.id}" />
          <div>
            <strong>${change.title}</strong>
            <p>${change.detail}</p>
          </div>
          <span>${change.type}</span>
        </label>
      `).join('');
    }

    function mapCloudChange(change) {
      return {
        id: change.id,
        type: change.change_type,
        title: change.entity_key || change.after_json?.name || change.before_json?.name || 'Track',
        detail:
          change.after_json?.path
          || change.before_json?.path
          || change.after_json?.detail
          || change.before_json?.detail
          || 'Cambio recibido desde el agente local.',
        before_json: change.before_json || null,
        after_json: change.after_json || null,
      };
    }

    function hydrateWorkspaceFromCloud(latestSnapshot, latestCloudChanges = []) {
      if (!latestSnapshot) return;

      currentSnapshot = latestSnapshot.snapshot_json || [];
      currentWorkingSnapshotId = latestSnapshot.id || currentWorkingSnapshotId;

      if (sourceName) {
        sourceName.textContent = latestSnapshot.root_path
          ? latestSnapshot.root_path.split('/').filter(Boolean).at(-1) || latestSnapshot.root_path
          : latestSnapshot.label || 'Snapshot cloud';
      }

      if (sourceMeta) {
        sourceMeta.textContent = `${latestSnapshot.file_count || currentSnapshot.length} archivos cargados desde el último sync del agente.`;
      }

      renderFiles(
        currentSnapshot,
        'Aún no hay archivos subidos por el agente cloud para esta librería.',
      );

      if (latestCloudChanges.length) {
        renderChanges(latestCloudChanges.map(mapCloudChange));
      } else {
        renderChanges([]);
      }
    }

    function renderCloudChangeSets(changeSets) {
      if (!prList || !prCount) return;

      if (!changeSets.length) {
        prCount.textContent = '0 activas';
        prList.innerHTML = '<div class="workspace-empty">Todavía no hay solicitudes guardadas. Cuando compartas cambios o envíes música al pool, aparecerá aquí.</div>';
        return;
      }

      prCount.textContent = `${changeSets.length} activas`;
      prList.innerHTML = changeSets.map((pr) => `
        <article class="workspace-pr-card is-${pr.status === 'open' ? 'review' : pr.status}">
          <div class="workspace-pr-card-head">
            <strong>${pr.title}</strong>
            <span>${pr.status}</span>
          </div>
          <p>${pr.description || 'Sin descripcion adicional.'}</p>
          <small>Destino: ${pr.target_kind === 'master' ? '0_MASTER LIBRARY' : 'Mi libreria'} · ${formatDate(pr.created_at)}</small>
          ${pr.review_notes ? `<small>Review: ${pr.review_notes}</small>` : ''}
        </article>
      `).join('');
    }

    function renderCloudSnapshots(snapshots) {
      if (!snapshotTimeline || !snapshotCount) return;

      if (!snapshots.length) {
        snapshotCount.textContent = '0 guardados';
        snapshotTimeline.innerHTML = '<div class="workspace-empty">Inicia sesión y guarda un primer estado para empezar a crear tu historial.</div>';
        return;
      }

      snapshotCount.textContent = `${snapshots.length} guardados`;
      snapshotTimeline.innerHTML = snapshots.map((snapshot) => `
        <article class="workspace-timeline-card">
          <div class="workspace-timeline-head">
            <strong>${snapshot.label || 'Snapshot sin nombre'}</strong>
            <span>${formatDate(snapshot.created_at)}</span>
          </div>
          <p>${snapshot.file_count} archivos · ${formatBytes(snapshot.total_bytes)} · origen ${snapshot.source_kind}</p>
          <small>${snapshot.root_path || 'Ruta no indicada'}</small>
        </article>
      `).join('');
    }

    function updateCloudStatus(mode, copy) {
      if (cloudBadge) cloudBadge.textContent = mode;
      if (cloudCopy) cloudCopy.textContent = copy;
    }

    async function ensureCloudContext() {
      if (!isSupabaseConfigured || !supabase) {
        updateCloudStatus('Sin Supabase', 'Faltan variables de entorno para guardar snapshots en cloud.');
        return false;
      }

      const { data: sessionData } = await supabase.auth.getSession();
      const session = sessionData.session;

      if (!session) {
        updateCloudStatus('Modo local', 'Inicia sesión para que el historial y los cambios queden guardados dentro de tu biblioteca personal.');
        if (cloudUser) cloudUser.textContent = 'Sin sesion iniciada';
        if (cloudLibrary) cloudLibrary.textContent = 'No hay libreria cloud activa.';
        return false;
      }

      const { data: profile } = await supabase
        .from('profiles')
        .select('id, email, display_name, slug')
        .eq('id', session.user.id)
        .single();

      currentProfile = profile || null;

      let { data: library } = await supabase
        .from('libraries')
        .select('id, name, slug, kind, profile_id, current_working_snapshot_id, current_published_snapshot_id')
        .eq('profile_id', session.user.id)
        .eq('kind', 'personal')
        .maybeSingle();

      if (!library) {
        const payload = {
          profile_id: session.user.id,
          name: `${profile?.display_name || 'DJ'} Library`,
          slug: `${profile?.slug || session.user.id}-library`,
          kind: 'personal',
          is_public: false,
        };

        const inserted = await supabase
          .from('libraries')
          .insert(payload)
          .select('id, name, slug, kind, profile_id, current_working_snapshot_id, current_published_snapshot_id')
          .single();

        if (inserted.error) {
          updateCloudStatus('Error', 'No he podido resolver tu libreria cloud todavia.');
          if (cloudUser) cloudUser.textContent = profile?.email || session.user.email || 'Usuario conectado';
          if (cloudLibrary) cloudLibrary.textContent = inserted.error.message;
          return false;
        }

        library = inserted.data;
      }

      currentLibrary = library;
      currentWorkingSnapshotId = library.current_working_snapshot_id || '';
      if (title && profile?.display_name) {
        title.textContent = `${profile.display_name} / ${activeBranch()?.name || 'working'}`;
      }
      updateCloudStatus('Cloud activo', 'Cada estado que guardes puede quedar disponible para el historial de tu biblioteca.');
      if (cloudUser) cloudUser.textContent = profile?.display_name || profile?.email || session.user.email || 'Usuario conectado';
      if (cloudLibrary) cloudLibrary.textContent = `${library.name} · ${library.slug}${library.current_published_snapshot_id ? ' · published activo' : ''}`;
      return true;
    }

    async function loadCloudHistory() {
      const ready = await ensureCloudContext();
      if (!ready || !currentLibrary || !supabase) {
        renderCloudSnapshots([]);
        renderCloudChangeSets([]);
        return;
      }

      const [snapshotResult, changeSetResult] = await Promise.all([
        supabase
          .from('library_snapshots')
          .select('id, label, source_kind, root_path, file_count, total_bytes, created_at, snapshot_json')
          .eq('library_id', currentLibrary.id)
          .order('created_at', { ascending: false })
          .limit(6),
        supabase
          .from('library_change_sets')
          .select('id, title, description, review_notes, target_kind, status, created_at')
          .eq('library_id', currentLibrary.id)
          .order('created_at', { ascending: false })
          .limit(6),
      ]);

      const snapshots = snapshotResult.data || [];
      const changeSets = changeSetResult.data || [];

      renderCloudSnapshots(snapshots);
      renderCloudChangeSets(changeSets);
      renderGitGraph(buildCloudGraphRows(snapshots, changeSets));

      const latestOpenChangeSet = changeSets.find((item) => item.status === 'open' || item.status === 'draft') || null;
      let latestChanges = [];

      if (latestOpenChangeSet) {
        const changeDetailResult = await supabase
          .from('library_changes')
          .select('id, change_type, entity_key, before_json, after_json, selected_for_master, created_at')
          .eq('change_set_id', latestOpenChangeSet.id)
          .order('created_at', { ascending: true });

        latestChanges = changeDetailResult.data || [];
      }

      if (!hasLocalSelection && snapshots.length) {
        hydrateWorkspaceFromCloud(snapshots[0], latestChanges);
      }
    }

    function refreshFromSnapshot(snapshot) {
      currentSnapshot = snapshot;
      const previousSnapshot = readStoredSnapshot();
      const changes = diffSnapshots(previousSnapshot, snapshot);
      renderFiles(snapshot);
      renderChanges(changes);
    }

    input?.addEventListener('change', (event) => {
      hasLocalSelection = true;
      const files = Array.from(event.target.files || []);
      const snapshot = createSnapshot(files);
      const root = snapshot[0]?.path?.split('/')?.[0] || 'Libreria local';

      title.textContent = `${root} / Biblioteca en curso`;
      sourceName.textContent = root;
      sourceMeta.textContent = `${snapshot.length} archivos detectados en esta lectura local.`;
      refreshFromSnapshot(snapshot);
      syncBranchContext();
    });

    saveSnapshotButton?.addEventListener('click', async () => {
      if (!currentSnapshot.length) {
        sourceMeta.textContent = 'Primero conecta una carpeta local para poder guardar un estado.';
        return;
      }

      writeStoredSnapshot(currentSnapshot);
      sourceMeta.textContent = `Estado local guardado con ${currentSnapshot.length} archivos.`;

      const ready = await ensureCloudContext();
      if (ready && currentLibrary && currentProfile && supabase) {
        const payload = {
          library_id: currentLibrary.id,
          created_by: currentProfile.id,
          label: `${activeBranch()?.name || 'working'} · ${sourceName?.textContent || 'Workspace'} estado`,
          source_kind: 'browser_demo',
          root_path: `${activeBranch()?.name || 'working'}:${sourceName?.textContent || 'local'}`,
          file_count: currentSnapshot.length,
          total_bytes: totalBytes(currentSnapshot),
          snapshot_json: currentSnapshot,
        };

        const insertResult = await supabase.from('library_snapshots').insert(payload).select('id').single();

        if (insertResult.error) {
          sourceMeta.textContent = `El estado local se guardó, pero la sincronización cloud ha fallado: ${insertResult.error.message}`;
        } else {
          currentWorkingSnapshotId = insertResult.data.id;
          await supabase
            .from('libraries')
            .update({
              current_working_snapshot_id: insertResult.data.id,
              updated_at: new Date().toISOString(),
            })
            .eq('id', currentLibrary.id);
          sourceMeta.textContent = `Estado local y cloud guardado con ${currentSnapshot.length} archivos.`;
          await loadCloudHistory();
        }
      }

      refreshFromSnapshot(currentSnapshot);
    });

    mergePublishedButton?.addEventListener('click', async () => {
      if (!currentSnapshot.length) {
        sourceMeta.textContent = 'Primero conecta una carpeta local y guarda un estado.';
        return;
      }

      const ready = await ensureCloudContext();
      if (!ready || !currentLibrary || !currentProfile || !supabase) return;

      if (!currentWorkingSnapshotId) {
        sourceMeta.textContent = 'Guarda primero el estado actual en cloud antes de pasarlo a estable.';
        return;
      }

      const changeSetInsert = await supabase
        .from('library_change_sets')
        .insert({
          library_id: currentLibrary.id,
          created_by: currentProfile.id,
          reviewed_by: currentProfile.id,
          title: `Merge ${activeBranch()?.name || 'working'} -> published · ${new Date().toLocaleDateString('es-ES')}`,
          description: `${currentChanges.length} cambios aceptados desde la rama ${activeBranch()?.name || 'working'} hacia la biblioteca estable.`,
          review_notes: `Merge directo desde la rama ${activeBranch()?.name || 'working'} del DJ.`,
          target_kind: 'library',
          status: 'merged',
          to_snapshot_id: currentWorkingSnapshotId,
          merged_at: new Date().toISOString(),
        });

      if (changeSetInsert.error) {
        sourceMeta.textContent = `No he podido registrar el paso a estable: ${changeSetInsert.error.message}`;
        return;
      }

      const libraryUpdate = await supabase
        .from('libraries')
        .update({
          current_published_snapshot_id: currentWorkingSnapshotId,
          updated_at: new Date().toISOString(),
        })
        .eq('id', currentLibrary.id)
        .select('id, name, slug, kind, profile_id, current_working_snapshot_id, current_published_snapshot_id')
        .single();

      if (libraryUpdate.error) {
        sourceMeta.textContent = `El cambio quedó registrado, pero no pude actualizar la versión estable: ${libraryUpdate.error.message}`;
        return;
      }

      currentLibrary = libraryUpdate.data;
      writeStoredSnapshot(currentSnapshot);
      sourceMeta.textContent = 'La versión estable ya está actualizada. Todo vuelve a quedar alineado.';
      refreshFromSnapshot(currentSnapshot);
      await loadCloudHistory();
    });

    stageSelectionButton?.addEventListener('click', async () => {
      const selected = Array.from(document.querySelectorAll('[data-change-id]:checked'));
      if (!selected.length) {
        sourceMeta.textContent = 'Marca uno o varios cambios antes de preparar una PR musical.';
        return;
      }

      sourceMeta.textContent = `${selected.length} cambios marcados para compartir o revisar.`;
      const ready = await ensureCloudContext();
      if (!ready || !currentLibrary || !currentProfile || !supabase) return;

      const changeSetResult = await supabase
        .from('library_change_sets')
        .insert({
          library_id: currentLibrary.id,
          created_by: currentProfile.id,
          title: `PR ${activeBranch()?.name || 'working'} -> 0_MASTER · ${new Date().toLocaleDateString('es-ES')}`,
          description: `${selected.length} cambios preparados desde la rama ${activeBranch()?.name || 'working'} para revisión antes de entrar en la biblioteca compartida.`,
          target_kind: 'master',
          status: 'open',
          from_snapshot_id: currentLibrary.current_published_snapshot_id || null,
          to_snapshot_id: currentWorkingSnapshotId || null,
        })
        .select('id')
        .single();

      if (changeSetResult.error) {
        sourceMeta.textContent = `No he podido crear la solicitud cloud: ${changeSetResult.error.message}`;
        return;
      }

      const selectedIds = new Set(selected.map((item) => item.dataset.changeId));
      const selectedChanges = currentChanges.filter((change) => selectedIds.has(change.id));
      const rows = selectedChanges.map((change) => ({
        change_set_id: changeSetResult.data.id,
        entity_type: 'track',
        change_type: change.type,
        entity_key: change.title,
        before_json: change.type === 'added' ? null : (change.before_json || { detail: change.detail }),
        after_json: change.type === 'removed' ? null : (change.after_json || { detail: change.detail }),
        selected_for_master: true,
      }));

      const { error } = await supabase.from('library_changes').insert(rows);
      if (error) {
        sourceMeta.textContent = `He creado la solicitud, pero no pude guardar el detalle de sus cambios: ${error.message}`;
        return;
      }

      sourceMeta.textContent = `Solicitud cloud creada con ${selectedChanges.length} cambios.`;
      await loadCloudHistory();
    });

    const previousSnapshot = readStoredSnapshot();
    if (previousSnapshot.length) {
      sourceMeta.textContent = `Hay un estado guardado con ${previousSnapshot.length} archivos listo para comparar.`;
    }

    branchForm?.addEventListener('submit', (event) => {
      event.preventDefault();
      createBranch(branchNameInput instanceof HTMLInputElement ? branchNameInput.value : '');
    });

    renderBranches();
    syncBranchContext();
    renderGitGraph();
    loadCloudHistory();
  </script>
</BaseLayout>
